---
import Layout from '../../../layouts/Layout.astro';

const docs = [
  {
    slug: 'webinar-2026-04-28',
    title: 'Recruiting Webinar (Apr 28, 2026) — Takeaways',
    summary: 'TheAllianceFP × Sports Recruits panel. TL;DR + 14-row agree/disagree table with Stars POV. Use this to anchor camp talking points and to onboard new staff.',
    tag: 'Reference',
  },
  {
    slug: 'camp-may-9-parent-email',
    title: 'Camp May 9 — Parent + Player Email',
    summary: 'Pre-camp email to families. Sets up the recruiting reset and asks for top-10 schools, last camp, last video, coaches contacted, one honest sentence on the spring. Reply deadline May 7.',
    tag: 'Camp prep',
  },
  {
    slug: 'camp-may-9-video-script',
    title: 'Camp May 9 — Pre-Camp Video Script',
    summary: '4-5 min talking-head script for Mike to record (Loom or podcast studio). Goes out same week as parent email.',
    tag: 'Camp prep',
  },
  {
    slug: 'camp-may-9-evening-outline',
    title: 'Camp May 9 — Evening Recruiting Session Run-of-Show',
    summary: '75-90 min session. Setup checklist, time-boxed flow, per-player station logistics, post-session follow-ups, failure modes.',
    tag: 'Camp prep',
  },
];
---

<Layout title="Admin Help & Reference | Stars National Walker" noindex={true}>
  <div class="min-h-screen bg-gray-100">
    <div id="loading" class="flex items-center justify-center min-h-screen">
      <div class="text-gray-500">Loading...</div>
    </div>

    <div id="content" class="hidden">
      <header class="bg-stars-navy text-white shadow-lg">
        <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <img src="/logo.webp" alt="Stars National Walker" class="h-10" />
            <div>
              <h1 class="text-xl font-bold">Admin Help & Reference</h1>
              <p class="text-sm text-white/70">Internal docs for staff + coaches</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <a href="/admin/dashboard" class="px-3 py-2 bg-white/10 hover:bg-white/20 rounded-lg text-sm">Dashboard</a>
            <a href="/admin/pitchers" class="px-3 py-2 bg-amber-500 hover:bg-amber-600 rounded-lg text-sm">Pitcher Hunt</a>
            <a href="/admin/teams" class="px-3 py-2 bg-white/10 hover:bg-white/20 rounded-lg text-sm">Teams</a>
            <button id="logout-btn" class="px-3 py-2 bg-stars-red hover:bg-red-700 rounded-lg text-sm">Logout</button>
          </div>
        </div>
      </header>

      <div class="max-w-5xl mx-auto px-4 py-8 space-y-4">
        {docs.map((d) => (
          <a href={`/admin/help/${d.slug}`} class="block bg-white rounded-xl shadow hover:shadow-md transition p-6 group">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs font-semibold uppercase tracking-wide text-stars-navy/60">{d.tag}</span>
                </div>
                <h2 class="text-lg font-bold text-gray-900 group-hover:text-stars-navy">{d.title}</h2>
                <p class="text-sm text-gray-600 mt-2 leading-relaxed">{d.summary}</p>
              </div>
              <div class="text-stars-navy text-xl group-hover:translate-x-1 transition-transform">→</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <script is:inline>
    const AUTH_KEY = 'snw_admin_auth';
    if (sessionStorage.getItem(AUTH_KEY) !== 'true') {
      window.location.href = '/admin/';
    } else {
      document.getElementById('loading').classList.add('hidden');
      document.getElementById('content').classList.remove('hidden');
    }
    document.getElementById('logout-btn').addEventListener('click', function() {
      sessionStorage.removeItem(AUTH_KEY);
      window.location.href = '/admin/';
    });
  </script>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Family Sign-In | Stars National Walker" noindex={true}>
  <div class="min-h-screen flex items-center justify-center bg-stars-navy py-12 px-4">
    <div class="max-w-md w-full">
      <div class="text-center mb-8">
        <img src="/logo.webp" alt="Stars National Walker" class="h-20 mx-auto mb-4" />
        <h1 class="text-2xl font-bold text-white">Family Sign-In</h1>
        <p class="text-white/70 text-sm mt-2">For Stars National Walker players + parents</p>
      </div>

      <form id="login-form" class="bg-white rounded-xl shadow-2xl p-8">
        <div class="space-y-5">
          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
              Family password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-stars-navy focus:border-transparent"
              placeholder="Enter password"
              autofocus
            />
            <p class="text-xs text-gray-500 mt-2">Mike sent this to you. If you don't have it, email <a href="mailto:mike@southlandorganics.com" class="text-stars-navy hover:underline">mike@southlandorganics.com</a>.</p>
          </div>

          <div id="error-msg" class="hidden text-red-600 text-sm text-center"></div>

          <button
            type="submit"
            class="w-full bg-stars-navy hover:bg-stars-blue text-white font-bold py-3 px-4 rounded-lg transition-colors"
          >
            Sign In
          </button>
        </div>
      </form>

      <p class="text-center text-white/50 text-sm mt-6">
        <a href="/" class="hover:text-white transition-colors">&larr; Back to site</a>
      </p>
    </div>
  </div>

  <script is:inline>
    const FAMILY_PASS = 'starsfamily';
    const AUTH_KEY = 'snw_family_auth';

    if (sessionStorage.getItem(AUTH_KEY) === 'true') {
      window.location.replace('/family/');
    }

    document.getElementById('login-form').addEventListener('submit', (e) => {
      e.preventDefault();
      const pw = document.getElementById('password').value.trim().toLowerCase();
      const errorMsg = document.getElementById('error-msg');
      if (pw === FAMILY_PASS) {
        sessionStorage.setItem(AUTH_KEY, 'true');
        window.location.replace('/family/');
      } else {
        errorMsg.textContent = 'Wrong password. Try again or email Mike.';
        errorMsg.classList.remove('hidden');
      }
    });
  </script>
</Layout>

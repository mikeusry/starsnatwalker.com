---
interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Stars National Walker - Elite 16U Travel Softball Team based in Charlotte, NC with players from around the country. Competing in top-tier national tournaments and dedicated to player development and college placement.",
  image = "/og.png",
  noindex = false
} = Astro.props;

const siteUrl = "https://starsnatwalker.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);

// Structured data for organization
const organizationStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'SportsTeam',
  name: 'Stars National Walker',
  sport: 'Softball',
  url: siteUrl,
  logo: `${siteUrl}/logo.webp`,
  location: {
    '@type': 'Place',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Charlotte',
      addressRegion: 'NC',
      addressCountry: 'US',
    },
  },
  memberOf: {
    '@type': 'SportsOrganization',
    name: 'Stars National Softball',
  },
  ...(description && { description }),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Keywords -->
    <meta name="keywords" content="Stars National Walker, 16U softball, travel softball, Charlotte softball, North Carolina softball, college softball recruiting, Stars National Softball, youth softball, elite softball team, softball players, NCAA softball" />

    <!-- Author and Copyright -->
    <meta name="author" content="Stars National Walker" />
    <meta name="copyright" content="Stars National Walker" />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Stars National Walker" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image && image.startsWith('http') ? image : `${siteUrl}${image || '/logo.webp'}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@StarsNatWalker" />
    <meta name="twitter:creator" content="@StarsNatWalker" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image && image.startsWith('http') ? image : `${siteUrl}${image || '/logo.webp'}`} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationStructuredData)} />

    <!-- Preload LCP image -->
    <link rel="preload" as="image" href="/team.webp" type="image/webp" fetchpriority="high" />

    <!-- Fonts - Non-blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    </noscript>

    <!-- Styles -->
    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <slot />

    <!-- pd-pixel: Profile view tracking -->
    <script is:inline>
      (function() {
        var SUPABASE_URL = 'https://dludfgxxjstzpbrrysqp.supabase.co';
        var SUPABASE_ANON_KEY = 'sb_publishable_z-ud8xw7O743S00vGnN3fg_xtTbM7ot';
        var SITE_ID = 'starsnatwalker';

        function getSessionId() {
          var s = sessionStorage.getItem('pd_sid');
          if (!s) {
            s = 's_' + Math.random().toString(36).slice(2,11) + Date.now().toString(36);
            sessionStorage.setItem('pd_sid', s);
          }
          return s;
        }

        function getGeoData() {
          var cached = sessionStorage.getItem('pd_geo');
          if (cached) {
            try { return JSON.parse(cached); } catch(e) {}
          }
          return null;
        }

        function fetchGeoData(callback) {
          var cached = getGeoData();
          if (cached) { callback(cached); return; }
          fetch('https://ipapi.co/json/')
            .then(function(r) { return r.json(); })
            .then(function(data) {
              var geo = {
                city: data.city || null,
                region: data.region || null,
                country: data.country_name || null
              };
              sessionStorage.setItem('pd_geo', JSON.stringify(geo));
              callback(geo);
            })
            .catch(function() { callback({ city: null, region: null, country: null }); });
        }

        function isBot() {
          return /bot|crawl|spider|slurp|bingpreview|facebook|mediapartners/i.test(navigator.userAgent);
        }

        function getPlayerInfo() {
          var m = location.pathname.match(/\/players\/([^\/]+)/);
          return m ? { slug: m[1], name: (document.querySelector('h1') || {}).textContent || null } : null;
        }

        function track(eventType, eventData) {
          if (isBot()) return;
          var p = getPlayerInfo();
          var basePayload = {
            site: SITE_ID,
            player_slug: p ? p.slug : location.pathname,
            player_name: p ? p.name : null,
            page_path: location.pathname,
            referrer: document.referrer || 'direct',
            user_agent: navigator.userAgent,
            session_id: getSessionId(),
            is_bot: false,
            event_type: eventType,
            event_data: eventData || null
          };

          fetchGeoData(function(geo) {
            var payload = Object.assign({}, basePayload, {
              city: geo.city,
              region: geo.region,
              country: geo.country
            });
            fetch(SUPABASE_URL + '/rest/v1/profile_views', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'apikey': SUPABASE_ANON_KEY,
                'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
                'Prefer': 'return=minimal'
              },
              body: JSON.stringify(payload),
              keepalive: true
            }).catch(function(){});
          });
        }

        window.pdTrack = track;

        if (location.pathname.indexOf('/players/') === 0) {
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() { track('page_view'); });
          } else {
            track('page_view');
          }
        }
      })();
    </script>
  </body>
</html>
